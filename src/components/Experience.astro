---
import SectionHeader from './SectionHeader.astro';
import Icon from './Icon.astro';
import { experiences } from '../data/experience';
---
<section id="experience" class="section">
  <div class="container">
    <SectionHeader cmd="cat experience.md" title="Experience" />
    <div style="display:flex; flex-direction:column; gap:16px;">
      {experiences.map((exp) => (
        <div class="card">
          <div class="card-bar">
            {exp.icon && (
              <span class="ico" style="color:#c9d1d9; display:inline-flex;"><Icon name={exp.icon} size={18} /></span>
            )}
            <span class="path">{exp.company}</span>
            <span class="gh mono" style="margin-left:auto; font-size:12px;">{exp.dates}</span>
          </div>
          <div class="card-body">
            <h3 style="font-size:16px; margin-bottom:6px;">{exp.role}</h3>
            <p>{exp.summary}</p>
            {exp.highlights && (
              <ul style="margin:12px 0 0; padding-left:18px;">
                {exp.highlights.map((h) => (
                  <li style="font-size:14px; color:#b6bfca; margin-bottom:6px;">{h}</li>
                ))}
              </ul>
            )}
            <div style="margin-top:12px;">
              {exp.areas.map((a) => <span class="tag">{a}</span>)}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
